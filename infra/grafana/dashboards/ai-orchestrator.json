{
  "title": "AI Orchestrator",
  "uid": "ai-orch-v1",
  "schemaVersion": 39,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Jobs Submitted (total)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "sum(jobs_submitted_total)", "legendFormat": "Total"}],
      "options": {"colorMode": "background"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Jobs per Second",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "rate(jobs_submitted_total[1m])", "legendFormat": "RPS"}]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Job Submission Rate by Type",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "rate(jobs_submitted_total{job_type=\"vision\"}[1m])", "legendFormat": "Vision"},
        {"expr": "rate(jobs_submitted_total{job_type=\"llm\"}[1m])", "legendFormat": "LLM"}
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "p50 / p95 Job Latency (s)",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.5, rate(job_duration_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(job_duration_seconds_bucket[5m]))", "legendFormat": "p95"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latency by Backend",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(job_duration_seconds_bucket{backend=\"intel-igpu-openvino\"}[5m])) by (le))", "legendFormat": "Intel iGPU p95"},
        {"expr": "histogram_quantile(0.95, sum(rate(job_duration_seconds_bucket{backend=\"amd-wx3100-vulkan\"}[5m])) by (le))", "legendFormat": "AMD WX3100 p95"}
      ]
    }
  ]
}
